{
  "buildCommand": "echo 'Static site'",
  "outputDirectory": ".",
  "installCommand": "npm install --omit=optional",
  "functions": {
    "api/contact.js": {
      "maxDuration": 30
    },
    "api/gallery.js": {
      "maxDuration": 30
    }
  },
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "beiaibaking.net" }],
      "destination": "https://www.beiaibaking.net/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/blog.html",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/admin",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-store, max-age=0, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/admin/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-store, max-age=0, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/favicon.ico", "destination": "/assets/images/logo.png" }
  ]
}
