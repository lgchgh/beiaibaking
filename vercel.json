{
  "buildCommand": "echo 'Static site'",
  "outputDirectory": ".",
  "installCommand": "npm install --omit=optional",
  "functions": {
    "api/contact.js": {
      "maxDuration": 30
    },
    "api/gallery.js": {
      "maxDuration": 30
    },
    "api/posts.js": {
      "maxDuration": 60
    },
    "api/sitemap.js": {
      "maxDuration": 15
    },
    "api/post-page.js": {
      "maxDuration": 30,
      "includeFiles": "templates/post.html"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/blog.html",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/gallery.html",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/admin",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-store, max-age=0, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/admin/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-store, max-age=0, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/post.html", "destination": "/api/post-page" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/api/publish-scheduled", "destination": "/api/posts?__publishDue=1" },
    { "source": "/api/logout", "destination": "/api/login?__action=logout" },
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/favicon.ico", "destination": "/assets/images/logo.png" }
  ]
}
